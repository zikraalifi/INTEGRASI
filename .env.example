
# Backend (server/) — required
# ============================================================

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Backend server port (default 8787)
PORT=8787

# Allowed CORS origin (Vite dev server default)
ALLOWED_ORIGIN=http://localhost:5173


# ============================================================
# Frontend (Vite) — optional

# Override backend URL kalau backend jalan di host/port lain.
# VITE_API_URL=http://localhost:8787

# Switch chat widget ke mock (keyword-based, no AI call).
# Berguna untuk: kerja UI/styling tanpa start backend, demo offline,
# atau hemat API call saat develop layout. Default (gak di-set / kosong) = pakai backend real.
# VITE_USE_MOCK_API=true
